# ===========================
# DermAI Project .gitignore
# ===========================

# ---------- Node / Frontend ----------
node_modules/
.next/
out/
build/
dist/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---------- Python / Backend ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
*.egg-info/
*.egg

# ---------- ML Model (too large for git) ----------
*.keras
*.h5
*.pb
*.tflite
*.onnx

# ---------- IDE & OS ----------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ---------- Environment ----------
.env
.env.*

# ---------- Logs ----------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ---------- Build / Cache ----------
.vite/
.turbo/
.vercel/
coverage/

# ---------- TypeScript ----------
*.tsbuildinfo
next-env.d.ts

# ---------- Misc ----------
*.pem
